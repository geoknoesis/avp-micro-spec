# AVP-Micro settlement-rail registry (extensible SKOS scheme) + finality terms.
# Informative skos:note maps each rail to its real-world substrate. NON-NORMATIVE
# mappings; implementers MAY mint additional rail concepts in their own scheme.
#
# Namespace: https://w3id.org/avp-micro/settlement/v1#  (prefix stl:)
@prefix stl:  <https://w3id.org/avp-micro/settlement/v1#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

stl:RailScheme a skos:ConceptScheme ;
  skos:prefLabel "AVP-Micro settlement-rail scheme"@en ;
  skos:definition "An extensible set of settlement-rail concepts for on-chain binding."@en .

stl:rail-evm-stablecoin a skos:Concept ; skos:inScheme stl:RailScheme ;
  skos:prefLabel "EVM stablecoin"@en ;
  skos:definition "ERC-20 stablecoin transfer on an EVM chain (CAIP-2 eip155:*)."@en ;
  skos:note "Reference: USDC on Base. Finality by confirmation depth."@en .

stl:rail-x402 a skos:Concept ; skos:inScheme stl:RailScheme ;
  skos:prefLabel "Coinbase x402"@en ;
  skos:definition "HTTP 402 + stablecoin settlement for agent/API micropayments."@en ;
  skos:note "Pay-then-serve; settlement proof is the facilitator's on-chain transfer."@en .

stl:rail-lightning a skos:Concept ; skos:inScheme stl:RailScheme ;
  skos:prefLabel "Bitcoin Lightning"@en ;
  skos:definition "Lightning Network payment; amounts in millisatoshi."@en ;
  skos:note "Finality is preimage reveal; escrow is native via hold-invoices."@en .

# Closed-processor (attested-finality) rails. Settlement happens inside a private
# processor, so finality is not publicly verifiable: the SettlementProof is an
# AttestedSettlementProof that embeds a processor attestation (see settlement.ttl).
stl:rail-card-stripe a skos:Concept ; skos:inScheme stl:RailScheme ;
  skos:prefLabel "Card via processor (Stripe)"@en ;
  skos:definition "Card settlement executed through a processor (Stripe as the worked example), authorize-then-capture."@en ;
  skos:note "Attested finality (payee- or processor-attested). Escrow maps to auth/capture; refunds/chargebacks map to the Disputes bundle."@en .

stl:rail-bank-rtp a skos:Concept ; skos:inScheme stl:RailScheme ;
  skos:prefLabel "Instant bank credit transfer (RTP)"@en ;
  skos:definition "Instant account-to-account credit transfer (FedNow / TCH RTP / SEPA Instant)."@en ;
  skos:note "Attested finality; push and irrevocable, so NO native escrow; a refund is a fresh credit transfer."@en .

stl:rail-paypal a skos:Concept ; skos:inScheme stl:RailScheme ;
  skos:prefLabel "PayPal wallet"@en ;
  skos:definition "Settlement through the PayPal wallet/processor (immediate capture)."@en ;
  skos:note "Attested finality (payee- or processor-attested); processor did:web:paypal.com; capture status COMPLETED. The same pattern fits other closed processors (Adyen, Zum Rails) and push-to-card networks (Visa Direct, Mastercard Send) by minting a rail concept and naming the processor DID."@en .

stl:rail-visa-direct a skos:Concept ; skos:inScheme stl:RailScheme ;
  skos:prefLabel "Visa Direct (push-to-card)"@en ;
  skos:definition "Push-to-card credit transfer via Visa Direct (Original Credit Transaction, OCT)."@en ;
  skos:note "Attested finality; network/processor did:web:visa.com; OCT terminal status approved (action code 00). A credit push with NO authorize/capture and NO native escrow, settling to a tokenized PAN; the ProcessorAccountBinding binds the payee DID to the receiving card credential. Mastercard Send (stl:rail-mc-send) is the analogous network."@en .
