# Concept IRIs: <#LocalName> with @base <https://w3id.org/avp-micro/cat> → https://w3id.org/avp-micro/cat#LocalName
@base <https://w3id.org/avp-micro/cat> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix agcs: <https://w3id.org/avp-micro/cat/scheme/> .

agcs:AgentServiceCategory a skos:ConceptScheme ;
  dct:title "AVP-Micro agent service categories"@en ;
  dct:description "Three-level SKOS hierarchy for classifying paid services in agent commerce (informative vocabulary)."@en ;
  owl:versionInfo "0.1.0" ;
  skos:hasTopConcept
  <#ComputeAndInference> ,
  <#DataKnowledgeAndFeeds> ,
  <#ToolingAndIntegration> ,
  <#MediaAndCreative> ,
  <#CommunicationsAndReach> ,
  <#HumanServices> ,
  <#MarketplaceAndDiscovery> ,
  <#PhysicalGoodsAndLogistics> ,
  <#TrustRiskAndCompliance> .

<#ComputeAndInference> a skos:Concept ;
  skos:prefLabel "Compute and inference"@en ;
  skos:notation "ComputeAndInference" ;
  skos:topConceptOf agcs:AgentServiceCategory ;
  skos:inScheme agcs:AgentServiceCategory .

