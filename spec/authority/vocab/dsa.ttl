# Delegated Spending Authority core RDFS/OWL ontology.
#
# Declares the classes and properties whose JSON-LD term mappings are defined in
# ../context/v1.jsonld, so that DSA credential and trust data has formal RDF
# semantics (rdfs:Class / rdf:Property, labels, comments, and conservative
# domains/ranges). This ontology is an interoperability aid; the JSON-LD context
# and the prose specification are authoritative for term identity and processing.
#
# Namespace: https://w3id.org/spending-authority/v1#  (prefix dsa:)
@prefix dsa:  <https://w3id.org/spending-authority/v1#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .

<https://w3id.org/spending-authority/v1> a owl:Ontology ;
  dct:title "Delegated Spending Authority core vocabulary"@en ;
  dct:description "Classes and properties for delegated spending authority: credentials, trust configuration, and identity."@en ;
  owl:versionInfo "0.1.0" .

#################################################################
# Authorization axis (capacity vs instance) -- the central distinction
#################################################################
#
# An authorization is one of exactly two kinds, distinguished by reuse: a CAPACITY
# can be presented repeatedly (standing power -- revocable, delegable, policy-like),
# whereas an INSTANCE is consumed once (a concrete act -- nonce-bound, single-use,
# liability-bearing). Commitments (a payee-signed quote/receipt/offer) and settlement
# facts (an execution) are NOT authorizations and are intentionally outside this
# hierarchy. See design note 2026-06-12-authorization-capacity-instance-axis.

dsa:Authorization a owl:Class ;
  rdfs:label "Authorization"@en ;
  rdfs:comment "The semantic concept of granted permission: what authority or approval exists. Specialized as a standing AuthorizationCapacity or a consumable AuthorizationInstance."@en .

dsa:AuthorizationCapacity a owl:Class ;
  rdfs:subClassOf dsa:Authorization ;
  rdfs:label "Authorization capacity"@en ;
  rdfs:comment "Standing authority: who may authorize and within what bounds. Re-presentable, revocable, and delegable; the home of revocation and delegation semantics. e.g. a spend envelope."@en .

dsa:AuthorizationInstance a owl:Class ;
  rdfs:subClassOf dsa:Authorization ;
  rdfs:label "Authorization instance"@en ;
  rdfs:comment "A single consumable authorization act: what was authorized, here and now. Nonce-bound, single-use, merchant-bound, and liability-bearing; the home of replay protection, liability, and audit. e.g. a cart approval or a payment authorization."@en .

#################################################################
# Classes
#################################################################

dsa:SpendingAuthorizationCredential a owl:Class ;
  rdfs:subClassOf dsa:AuthorizationCapacity ;
  rdfs:label "Spending authorization credential"@en ;
  rdfs:comment "A verifiable credential issued by a principal that constrains how a payer agent may spend. A standing AuthorizationCapacity: presented repeatedly, revocable via status, and delegable."@en .

dsa:PaymentCapabilityCredential a owl:Class ;
  rdfs:label "Payment capability credential"@en ;
  rdfs:comment "A verifiable credential attesting an agent's funding/account capability."@en .

dsa:MerchantCredential a owl:Class ;
  rdfs:label "Merchant credential"@en ;
  rdfs:comment "A third-party-attested credential about a payee service."@en .

dsa:TrustedIssuer a owl:Class ;
  rdfs:label "Trusted issuer"@en ;
  rdfs:comment "A trust-configuration entry naming a DID a deployment elects to trust, optionally scoped."@en .

dsa:IssuerScope a owl:Class ;
  rdfs:label "Issuer scope"@en ;
  rdfs:comment "Bounds on what a trusted issuer may authorize."@en .

#################################################################
# Authorization-chain relations (SEMANTIC -- never provenance)
#################################################################
#
# These relate authorizations by normative dependence. They MUST NOT be conflated
# with provenance relations (prov:wasDerivedFrom / prov:used / prov:wasAttributedTo),
# which describe artifact transformation and belong to the securing/bridge layer.
# A PaymentAuthorization exercises/conformsTo a SpendingAuthorizationCredential; it is
# NOT prov:wasDerivedFrom it.

dsa:enables a owl:ObjectProperty ;
  rdfs:domain dsa:AuthorizationCapacity ;
  rdfs:range dsa:AuthorizationInstance ;
  rdfs:label "enables"@en ;
  rdfs:comment "The standing capacity makes a consumable instance possible. Inverse of dsa:exercises."@en ;
  owl:inverseOf dsa:exercises .

dsa:exercises a owl:ObjectProperty ;
  rdfs:domain dsa:AuthorizationInstance ;
  rdfs:range dsa:AuthorizationCapacity ;
  rdfs:label "exercises"@en ;
  rdfs:comment "The instance draws on (consumes) the standing capacity it acts under. In AVP-Micro a PaymentAuthorization exercises the SpendingAuthorizationCredential it embeds in its verifiable presentation."@en .

dsa:conformsTo a owl:ObjectProperty ;
  rdfs:domain dsa:AuthorizationInstance ;
  rdfs:range dsa:AuthorizationCapacity ;
  rdfs:label "conforms to"@en ;
  rdfs:comment "Normative: the instance's terms (amount, payee, time) fall within the capacity's bounds. A verifier MUST reject an instance that does not conform to the capacity it exercises."@en .

dsa:mustMatch a owl:ObjectProperty ;
  rdfs:domain dsa:AuthorizationInstance ;
  rdfs:label "must match"@en ;
  rdfs:comment "A normative binding constraint: a field of the instance MUST equal the corresponding field of a referenced commitment (e.g. a quote). In AVP-Micro this is realized by digest binding (quoteDigest, requestHash). Without it, signatures prove artifact integrity but not chain correctness."@en .

#################################################################
# Object properties (node references / DIDs / IRIs)
#################################################################

dsa:allowedPayees a owl:ObjectProperty ; rdfs:label "allowed payees"@en ;
  rdfs:comment "Payee DIDs an agent may pay."@en .
dsa:allowedCategories a owl:ObjectProperty ; rdfs:label "allowed categories"@en ;
  rdfs:comment "Service-category IRIs an agent may pay."@en .
dsa:categories a owl:ObjectProperty ; rdfs:label "categories"@en ;
  rdfs:comment "Self- or third-party-asserted service-category IRIs."@en .
dsa:trustedIssuers a owl:ObjectProperty ; rdfs:label "trusted issuers"@en ;
  rdfs:comment "The set of TrustedIssuer entries in a trust configuration."@en ;
  rdfs:range dsa:TrustedIssuer .
dsa:issuerScope a owl:ObjectProperty ; rdfs:label "issuer scope"@en ;
  rdfs:domain dsa:TrustedIssuer ; rdfs:range dsa:IssuerScope .

#################################################################
# Datatype properties
#################################################################

dsa:currency a owl:DatatypeProperty ; rdfs:label "currency"@en ; rdfs:range xsd:string .
dsa:maxPerTransaction a owl:DatatypeProperty ; rdfs:label "max per transaction"@en ; rdfs:range xsd:string .
dsa:dailyLimit a owl:DatatypeProperty ; rdfs:label "daily limit"@en ; rdfs:range xsd:string .
dsa:maxDailyTotal a owl:DatatypeProperty ; rdfs:label "max daily total"@en ; rdfs:range xsd:string .
dsa:limitTimezone a owl:DatatypeProperty ; rdfs:label "limit timezone"@en ; rdfs:range xsd:string .
dsa:requiresApprovalAbove a owl:DatatypeProperty ; rdfs:label "requires approval above"@en ; rdfs:range xsd:string .
dsa:account a owl:DatatypeProperty ; rdfs:label "account"@en ; rdfs:range xsd:string .
dsa:asset a owl:DatatypeProperty ; rdfs:label "asset"@en ; rdfs:range xsd:string .
dsa:assetScale a owl:DatatypeProperty ; rdfs:label "asset scale"@en ; rdfs:range xsd:integer .
dsa:merchantName a owl:DatatypeProperty ; rdfs:label "merchant name"@en .
dsa:companyName a owl:DatatypeProperty ; rdfs:label "company name"@en .
