{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/avp-micro/interop/sd-jwt-vc/schemas/interop.schema.json",
  "title": "AVP-Micro -- SD-JWT-VC interop profile data objects",
  "description": "JSON Schema for the bridged forms. Orthogonality model: a bridged object keeps its native AVP-Micro semantic type and composes with the ONE SecuringDescriptor (the 'securing' member) via the bridgeSecured mixin; carrier/proof choices are never encoded in the type. $defs: the decoded SD-JWT-VC mandate payload (A->V export, SpendingAuthorityMandateClaims) and the bridged profiles of the semantic types (V->A import: SpendingAuthorizationCredential, PaymentQuote, PurchaseConfirmation, PaymentAuthorization). Validate an instance against the relevant $def.",
  "$defs": {
    "did": { "type": "string", "pattern": "^did:[a-z0-9]+:.+" },
    "decimal": {
      "type": "string",
      "description": "Non-negative decimal amount as a string.",
      "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]+)?$"
    },
    "positiveDecimal": {
      "type": "string",
      "description": "Strictly positive decimal amount as a string (matches the DSA bundle; a spend limit of \"0\" is rejected).",
      "pattern": "^(0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(\\.[0-9]+)?)$"
    },
    "compactSdJwt": {
      "type": "string",
      "description": "An SD-JWT (optionally with disclosures and a key-binding JWT), compact serialization: base64url segments joined by '.', disclosures joined by '~'.",
      "pattern": "^[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+(~[A-Za-z0-9_-]*)*$"
    },
    "compactPresentation": {
      "type": "string",
      "description": "An SD-JWT presentation: an issuer-signed JWS, '~', any disclosures, then a key-binding JWT.",
      "pattern": "^[A-Za-z0-9_-]+(\\.[A-Za-z0-9_-]+){2}~([A-Za-z0-9_-]*~)*[A-Za-z0-9_-]+(\\.[A-Za-z0-9_-]+){2}$"
    },

    "limits": {
      "type": "object",
      "description": "Spending constraints, mirroring DSA credentialSubject limit fields.",
      "properties": {
        "per_txn": { "$ref": "#/$defs/decimal" },
        "per_day": { "$ref": "#/$defs/decimal" },
        "tz": { "type": "string" },
        "approval_above": { "$ref": "#/$defs/decimal" }
      },
      "additionalProperties": false
    },

    "SpendingAuthorityMandateClaims": {
      "type": "object",
      "description": "The decoded payload of an SD-JWT-VC produced by exporting a DSA SpendingAuthorizationCredential (A->V). The 'avp_vc' member is present only for the proof-preserving embedded profile (vct ...+embedded).",
      "required": ["vct", "iss", "sub", "cnf", "currency"],
      "properties": {
        "vct": { "type": "string", "enum": ["mandate.spending-authority.avp", "mandate.spending-authority.avp+embedded"] },
        "iss": { "type": "string", "format": "uri" },
        "sub": { "type": "string", "format": "uri" },
        "cnf": {
          "type": "object",
          "description": "Holder key confirmation (RFC 7800). The agent key named as DSA credentialSubject.id.",
          "required": ["jwk"],
          "properties": { "jwk": { "type": "object" } }
        },
        "currency": { "type": "string" },
        "limits": { "$ref": "#/$defs/limits" },
        "allowed_payees": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "allowed_categories": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "nbf": { "type": "integer" },
        "exp": { "type": "integer" },
        "jti": { "type": "string" },
        "status": { "type": "object", "description": "IETF Token Status List reference." },
        "avp_vc": {
          "type": "string",
          "contentEncoding": "base64url",
          "description": "base64url of the exact JCS-canonical SpendingAuthorizationCredential bytes, including its ecdsa-jcs-2022 proof. Carries the authority in the proof-preserving profile."
        }
      }
    },

    "SecuringDescriptor": {
      "type": "object",
      "description": "The one securing/bridge axis (iop:securing): HOW a bridged object's authority is secured. Defined once and composed with every semantic type via the bridgeSecured mixin; absence of 'securing' on an object means native.",
      "required": ["mode", "profileVersion"],
      "properties": {
        "mode": { "type": "string", "enum": ["proof-preserving", "co-issued", "attested"] },
        "carrier": { "type": "string", "enum": ["sd-jwt-vc", "sd-jwt-vc+kb-jwt"] },
        "embedded": {
          "description": "Byte-faithful compact serialization of the original foreign signed object.",
          "oneOf": [
            { "$ref": "#/$defs/compactSdJwt" },
            { "$ref": "#/$defs/compactPresentation" }
          ]
        },
        "sourceVct": { "type": "string" },
        "attestingBridge": { "$ref": "#/$defs/did" },
        "importAdvisory": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "profileVersion": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "proof-preserving" } } },
          "then": { "required": ["embedded"] }
        },
        {
          "if": { "properties": { "mode": { "const": "attested" } } },
          "then": { "required": ["attestingBridge"] }
        }
      ]
    },

    "bridgeSecured": {
      "type": "object",
      "description": "Mixin composed (allOf) into every bridged semantic type: requires the securing descriptor and enforces the mode/proof interplay ONCE -- proof-preserving objects are unsigned projections (no-downgrade); co-issued and attested objects carry a native proof.",
      "required": ["securing"],
      "properties": {
        "securing": { "$ref": "#/$defs/SecuringDescriptor" }
      },
      "allOf": [
        {
          "if": { "properties": { "securing": { "properties": { "mode": { "const": "proof-preserving" } } } } },
          "then": { "not": { "required": ["proof"] } }
        },
        {
          "if": { "properties": { "securing": { "properties": { "mode": { "const": "co-issued" } } } } },
          "then": { "required": ["proof"] }
        },
        {
          "if": { "properties": { "securing": { "properties": { "mode": { "const": "attested" } } } } },
          "then": { "required": ["proof"] }
        }
      ]
    },

    "SpendingAuthorizationCredential": {
      "type": "object",
      "description": "The bridged (V->A imported) profile of a DSA SpendingAuthorizationCredential: native semantic type, plus the securing descriptor. The outer claims are a projection; in proof-preserving mode securing.embedded carries the authenticated authority. AP2 intent extras are carried semantic claims (NOT machine-enforced).",
      "required": ["@context", "type", "issuer", "credentialSubject"],
      "allOf": [ { "$ref": "#/$defs/bridgeSecured" } ],
      "properties": {
        "@context": {
          "type": "array",
          "prefixItems": [
            { "const": "https://www.w3.org/ns/credentials/v2" },
            { "const": "https://w3id.org/security/data-integrity/v2" },
            { "const": "https://w3id.org/spending-authority/v1" },
            { "const": "https://w3id.org/avp-micro/interop/sd-jwt-vc/v1" }
          ],
          "minItems": 4,
          "maxItems": 4
        },
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "array",
          "allOf": [
            { "contains": { "const": "VerifiableCredential" } },
            { "contains": { "const": "SpendingAuthorizationCredential" } }
          ]
        },
        "issuer": { "oneOf": [ { "$ref": "#/$defs/did" }, { "type": "object", "required": ["id"], "properties": { "id": { "$ref": "#/$defs/did" } } } ] },
        "validFrom": { "type": "string", "format": "date-time" },
        "validUntil": { "type": "string", "format": "date-time" },
        "credentialStatus": { "type": ["object", "array"] },
        "credentialSubject": {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": { "$ref": "#/$defs/did" },
            "currency": { "type": "string" },
            "maxPerTransaction": { "$ref": "#/$defs/positiveDecimal" },
            "dailyLimit": { "$ref": "#/$defs/positiveDecimal" },
            "limitTimezone": { "type": "string" },
            "requiresApprovalAbove": { "$ref": "#/$defs/positiveDecimal" },
            "allowedPayees": { "type": "array", "items": { "$ref": "#/$defs/did" } },
            "allowedCategories": { "type": "array", "items": { "type": "string", "format": "uri" } }
          }
        },
        "intentDescription": { "type": "string" },
        "itemConstraints": { "type": "array", "items": { "type": "string" } },
        "refundabilityRequired": { "type": "boolean" },
        "requiresPurchaseConfirmation": { "type": "boolean" },
        "proof": {
          "type": "object",
          "description": "Present in co-issued and attested modes; absent in proof-preserving mode (the outer object is then an unsigned projection).",
          "required": ["type", "cryptosuite", "created", "verificationMethod", "proofPurpose", "proofValue"],
          "properties": {
            "type": { "const": "DataIntegrityProof" },
            "cryptosuite": { "const": "ecdsa-jcs-2022" },
            "created": { "type": "string", "format": "date-time" },
            "verificationMethod": { "type": "string", "minLength": 1 },
            "proofPurpose": { "const": "assertionMethod" },
            "proofValue": { "type": "string", "pattern": "^z[1-9A-HJ-NP-Za-km-z]+$" }
          }
        }
      }
    },

    "PaymentAuthorization": {
      "type": "object",
      "description": "The bridged (V->A imported) profile of a PaymentAuthorization (per-purchase action, L3): native semantic type, plus the securing descriptor whose embedded presentation (carrier sd-jwt-vc+kb-jwt) carries the authenticated authority.",
      "required": ["@context", "type", "payer", "payee", "amount", "currency"],
      "allOf": [ { "$ref": "#/$defs/bridgeSecured" } ],
      "properties": {
        "@context": {
          "type": "array",
          "prefixItems": [
            { "const": "https://www.w3.org/ns/credentials/v2" },
            { "const": "https://w3id.org/security/data-integrity/v2" },
            { "const": "https://w3id.org/spending-authority/v1" },
            { "const": "https://w3id.org/avp-micro/v1" },
            { "const": "https://w3id.org/avp-micro/interop/sd-jwt-vc/v1" }
          ],
          "minItems": 5,
          "maxItems": 5
        },
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "array",
          "allOf": [
            { "contains": { "const": "PaymentAuthorization" } }
          ]
        },
        "payer": { "$ref": "#/$defs/did" },
        "payee": { "$ref": "#/$defs/did" },
        "amount": { "$ref": "#/$defs/decimal" },
        "currency": { "type": "string" },
        "quote": { "type": "string" },
        "quoteDigest": { "type": "string" },
        "requestHash": { "type": "string" },
        "settlementMethod": { "type": "string" },
        "settlementTarget": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "expires": { "type": "string", "format": "date-time" },
        "nonce": { "type": "string" },
        "wallet": { "$ref": "#/$defs/did" },
        "proof": { "type": "object" }
      }
    },

    "PaymentQuote": {
      "type": "object",
      "description": "The bridged (V->A imported) profile of a PaymentQuote, projected from an AP2 CartMandate: native semantic type, plus the securing descriptor whose embedded merchant-signed mandate carries the authenticated authority. requestHash binds the canonical cart.",
      "required": ["@context", "type", "payer", "payee", "amount", "currency", "requestHash"],
      "allOf": [ { "$ref": "#/$defs/bridgeSecured" } ],
      "properties": {
        "@context": {
          "type": "array",
          "prefixItems": [
            { "const": "https://www.w3.org/ns/credentials/v2" },
            { "const": "https://w3id.org/security/data-integrity/v2" },
            { "const": "https://w3id.org/spending-authority/v1" },
            { "const": "https://w3id.org/avp-micro/v1" },
            { "const": "https://w3id.org/avp-micro/interop/sd-jwt-vc/v1" }
          ],
          "minItems": 5, "maxItems": 5
        },
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "array",
          "allOf": [
            { "contains": { "const": "PaymentQuote" } }
          ]
        },
        "payer": { "$ref": "#/$defs/did" },
        "payee": { "$ref": "#/$defs/did" },
        "amount": { "$ref": "#/$defs/decimal" },
        "currency": { "type": "string" },
        "requestHash": { "type": "string" },
        "expires": { "type": "string", "format": "date-time" },
        "proof": { "type": "object" }
      }
    },

    "PurchaseConfirmation": {
      "type": "object",
      "description": "The bridged (V->A imported) profile of a PurchaseConfirmation, projected from an AP2 human-present cart approval: native semantic type, plus the securing descriptor whose embedded user-signed approval carries the authenticated authority. The proof, when present (co-issued), MUST be controlled by confirmedBy.",
      "required": ["@context", "type", "quote", "quoteDigest", "payer", "payee", "amount", "currency", "requestHash", "confirmedBy"],
      "allOf": [ { "$ref": "#/$defs/bridgeSecured" } ],
      "properties": {
        "@context": {
          "type": "array",
          "prefixItems": [
            { "const": "https://www.w3.org/ns/credentials/v2" },
            { "const": "https://w3id.org/security/data-integrity/v2" },
            { "const": "https://w3id.org/spending-authority/v1" },
            { "const": "https://w3id.org/avp-micro/v1" },
            { "const": "https://w3id.org/avp-micro/interop/sd-jwt-vc/v1" }
          ],
          "minItems": 5, "maxItems": 5
        },
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "array",
          "allOf": [
            { "contains": { "const": "PurchaseConfirmation" } }
          ]
        },
        "quote": { "type": "string" },
        "quoteDigest": { "type": "string" },
        "payer": { "$ref": "#/$defs/did" },
        "payee": { "$ref": "#/$defs/did" },
        "amount": { "$ref": "#/$defs/decimal" },
        "currency": { "type": "string" },
        "requestHash": { "type": "string" },
        "confirmedBy": { "$ref": "#/$defs/did" },
        "proof": { "type": "object" }
      }
    }
  }
}
