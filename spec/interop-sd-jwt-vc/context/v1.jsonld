{
  "@context": {
    "@version": 1.1,
    "@protected": true,
    "id": "@id",
    "type": "@type",
    "iop": "https://w3id.org/avp-micro/interop/sd-jwt-vc/v1#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "securing": {
      "@id": "iop:securing",
      "@context": {
        "@protected": true,
        "mode": { "@id": "iop:mode" },
        "carrier": { "@id": "iop:carrier" },
        "embedded": { "@id": "iop:embedded" },
        "sourceVct": { "@id": "iop:sourceVct" },
        "attestingBridge": { "@id": "iop:attestingBridge", "@type": "@id" },
        "importAdvisory": { "@id": "iop:importAdvisory", "@container": "@set" },
        "profileVersion": { "@id": "iop:profileVersion" }
      }
    },

    "intentDescription": { "@id": "iop:intentDescription" },
    "itemConstraints": { "@id": "iop:itemConstraints", "@container": "@set" },
    "refundabilityRequired": { "@id": "iop:refundabilityRequired" },
    "requiresPurchaseConfirmation": { "@id": "iop:requiresPurchaseConfirmation" }
  }
}
