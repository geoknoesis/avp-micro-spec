{
  "@context": {
    "@version": 1.1,
    "@protected": true,
    "id": "@id",
    "type": "@type",
    "iop": "https://w3id.org/avp-micro/interop/sd-jwt-vc/v1#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "EmbeddedSdJwtVcMandate": "iop:EmbeddedSdJwtVcMandate",
    "EmbeddedKbJwtAuthorization": "iop:EmbeddedKbJwtAuthorization",
