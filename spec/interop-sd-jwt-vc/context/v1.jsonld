    "EmbeddedCartUserConfirmation": "iop:EmbeddedCartUserConfirmation",

    "embeddedSdJwtVc": { "@id": "iop:embeddedSdJwtVc" },
    "embeddedKbJwtPresentation": { "@id": "iop:embeddedKbJwtPresentation" },
    "importAdvisory": { "@id": "iop:importAdvisory", "@container": "@set" },
    "bridgeMode": { "@id": "iop:bridgeMode" },
    "sourceVct": { "@id": "iop:sourceVct" },
    "attestingBridge": { "@id": "iop:attestingBridge", "@type": "@id" },
    "profileVersion": { "@id": "iop:profileVersion" },
    "embeddedCartMandate": { "@id": "iop:embeddedCartMandate" },
    "embeddedCartUserAuth": { "@id": "iop:embeddedCartUserAuth" },
