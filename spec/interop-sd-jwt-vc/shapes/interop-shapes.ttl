# AVP-Micro -- SD-JWT-VC interop profile SHACL shapes.
#
# Orthogonality: a bridged object keeps its native semantic type; the bridge axis is
# the ONE iop:securing descriptor. SHACL here validates only that axis -- a single
# SecuringDescriptorShape targeting every value of iop:securing (sh:targetObjectsOf,
# so the nested node needs no class marker). Authorization semantics are validated by
# the owning bundle's schema/shapes for native objects, and by the interop JSON Schema
# for unsigned projections (which intentionally relax proof requirements). The
# mode/proof interplay (no-downgrade etc.) is enforced once, in the JSON Schema's
# bridgeSecured mixin.
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix iop:  <https://w3id.org/avp-micro/interop/sd-jwt-vc/v1#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

iop:SecuringDescriptorShape
  a sh:NodeShape ;
  sh:targetObjectsOf iop:securing ;
  sh:property [
    sh:path iop:mode ;
    sh:nodeKind sh:Literal ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in ( "proof-preserving" "co-issued" "attested" ) ;
    sh:message "A securing descriptor MUST declare exactly one mode: proof-preserving, co-issued, or attested." ;
  ] ;
  sh:property [
    sh:path iop:carrier ;
    sh:nodeKind sh:Literal ;
    sh:maxCount 1 ;
    sh:in ( "sd-jwt-vc" "sd-jwt-vc+kb-jwt" ) ;
  ] ;
  sh:property [
    sh:path iop:embedded ;
    sh:nodeKind sh:Literal ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path iop:sourceVct ;
    sh:nodeKind sh:Literal ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path iop:attestingBridge ;
    sh:nodeKind sh:IRI ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path iop:profileVersion ;
    sh:nodeKind sh:Literal ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .
