  {
    "name": "dispute-upheld-chargeback",
    "description": "payer disputes the charge; evidence is exchanged; the payee offers partial, the arbiter upholds 0.75, and the wallet reverses that amount",
    "policy": {"currency": "USD", "maxPerTransaction": "5.00", "allowedPayees": ["payee"]},
    "balances": {"agent": "100.00"},
    "now": "2026-06-12T10:00:00Z",
    "steps": [
      {"action": "quote", "amount": "1.00"},
      {"action": "authorize"},
      {"action": "execute", "expect": {"status": "completed", "settled": "1.00"}},
      {"action": "receipt"},
      {"action": "dispute", "disputedAmount": "1.00", "reason": "disp:not-delivered", "arbiter": true,
       "claim": "Stream dropped ~75% of samples; charged for undelivered data.", "expect": "ok"},
      {"action": "dispute_evidence", "role": "payee", "evidenceType": "delivery-log", "expect": "ok"},
      {"action": "dispute_evidence", "role": "payer", "evidenceType": "client-log", "expect": "ok"},
      {"action": "dispute_resolution", "resolverRole": "payee", "outcome": "partial", "resolvedAmount": "0.50", "expect": "ok"},
      {"action": "dispute_resolution", "resolverRole": "arbiter", "outcome": "upheld", "resolvedAmount": "0.75", "expect": "ok"},
      {"action": "reversal", "cause": "dispute", "expect": "ok"}
    ],
    "finalBalances": {"agent": "99.75", "payee": "0.25"}
  },
